---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');

const sortedProjects = allProjects.sort((a, b) => b.data.releaseYear - a.data.releaseYear);

const projectsByYear = sortedProjects.reduce((acc, project) => {
  const year = project.data.releaseYear;
  if (!acc[year]) acc[year] = [];
  acc[year].push(project);
  return acc;
}, {} as Record<number, typeof sortedProjects>);

const years = Object.keys(projectsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Simon Gardier - Projects" activePage="projects">
  <div class="max-w-4xl mx-auto py-4">
    <div class="mb-10 text-center md:text-left">
      <h1 class="text-3xl md:text-4xl font-extrabold text-fg-dark my-0">Projects</h1>
      <p class="text-fg-light text-base mt-2">
        A collection of projects I am proud of. :)<br>
        More projects available on my <a href="https://github.com/simon-gardier">GitHub profile <span class="i-eva:github-outline text-sm"></span></a>
      </p>
    </div>

    <div class="space-y-12">
      {years.map(year => (
        <div>
          <div class="flex items-center gap-4 mb-4">
            <h2 class="text-2xl font-mono font-bold text-fg-dark">{year}</h2>
            <div class="flex-1 h-px bg-border"></div>
          </div>
          
          <ul class="space-y-8 list-none p-0">
            {projectsByYear[year].map(project => (
              <li class="flex flex-col sm:flex-row gap-5 items-start justify-between pl-4 py-1 hover:border-sky-500 transition-colors duration-300 relative group">
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="text-base md:text-lg font-bold text-fg-dark my-0 leading-snug">
                      {project.data.title}
                    </h3>
                    
                    <div class="flex gap-2">
                      {project.data.github && (
                        <a 
                          href={project.data.github} 
                          target="_blank" 
                          rel="noopener noreferrer" 
                          class="p-1.5 rounded-lg text-fg-light hover:text-fg-dark hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
                          aria-label="GitHub Repository"
                        >
                          <span class="i-eva:github-outline text-lg block"></span>
                        </a>
                      )}
                      {project.data.live && (
                        <a 
                          href={project.data.live} 
                          target="_blank" 
                          rel="noopener noreferrer" 
                          class="p-1.5 rounded-lg text-fg-light hover:text-sky-500 hover:bg-sky-500/5 transition-colors"
                          aria-label="Live Demo"
                        >
                          <span class="i-solar:planet-linear text-lg block"></span>
                        </a>
                      )}
                    </div>
                  </div>

                  <p class="text-sm text-fg-light mt-2 mb-3 leading-relaxed">
                    {project.data.description}
                  </p>

                  <div class="flex flex-wrap gap-1.5">
                    {project.data.techStack.map(tech => (
                      <span class="text-[10px] font-mono font-semibold px-2 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-fg-light group-hover:bg-sky-500/5 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors duration-200">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>

                {project.data.image ? (
                  <div class="w-full sm:w-48 h-36 sm:h-30 flex-shrink-0 border border-border rounded-lg overflow-hidden bg-white/10 dark:bg-black/10">
                    <img 
                      src={project.data.image} 
                      alt={project.data.title} 
                      class="w-full h-full object-cover filter transition-all duration-300 group-hover:scale-[1.01]" 
                    />
                  </div>
                ) : (
                  <div class="w-full sm:w-48 h-36 sm:h-30 flex-shrink-0 border border-dashed border-border rounded-lg flex items-center justify-center bg-bg-dark/10">
                    <span class="i-solar:planet-linear text-fg-light/40 text-lg"></span>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
