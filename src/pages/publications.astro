---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPublications = await getCollection('publications');

const sortedPubs = allPublications.sort((a, b) => b.data.year - a.data.year);

const pubsByYear = sortedPubs.reduce((acc, pub) => {
  const year = pub.data.year;
  if (!acc[year]) acc[year] = [];
  acc[year].push(pub);
  return acc;
}, {} as Record<number, typeof sortedPubs>);

const years = Object.keys(pubsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="Simon Gardier - Publications" activePage="publications">
  <div class="max-w-4xl mx-auto py-4">
    <div class="mb-10 text-center md:text-left">
      <h1 class="text-3xl md:text-4xl font-extrabold text-fg-dark my-0">Publications</h1>
      <p class="text-fg-light text-base mt-2">
        Conference papers, journal articles, preprints, surveys, etc. I worked on.
      </p>
    </div>

    <div class="space-y-12">
      {years.map(year => (
        <div>
          <div class="flex items-center gap-4 mb-4">
            <h2 class="text-2xl font-mono font-bold text-fg-dark">{year}</h2>
            <div class="flex-1 h-px bg-border"></div>
          </div>
          
          <ul class="space-y-8 list-none p-0">
            {pubsByYear[year].map(pub => (
              <li class="flex flex-col sm:flex-row gap-5 items-start justify-between pl-4 py-1 hover:border-sky-500 transition-colors duration-300">
                <div class="flex-1 min-w-0">
                  <h3 class="text-base md:text-lg font-bold text-fg-dark my-0 leading-snug">
                    {pub.data.title}
                  </h3>
                  
                  {/* Authors list */}
                  <p class="text-sm text-fg-light my-1 leading-relaxed">
                    {pub.data.authors.map((author, index) => {
                      const isSelf = author.toLowerCase().includes("rivera") || author.toLowerCase().includes("gardier") || author.toLowerCase().includes("you");
                      return (
                        <span>
                          {isSelf ? <u class="font-semibold text-fg-dark">{author}</u> : author}
                          {index < pub.data.authors.length - 1 ? ", " : ""}
                        </span>
                      );
                    })}
                  </p>

                  <p class="text-xs font-medium text-sky-500 my-1 font-mono">
                    {pub.data.journal}
                  </p>

                  <div class="flex items-center gap-3 mt-2 text-xs font-semibold">
                    {pub.data.link && (
                      <a 
                        href={pub.data.link} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-sky-500 dark:text-sky-400 no-underline hover:underline hover:text-sky-600 inline-hstack gap-1"
                      >
                        <span class="i-eva:link-outline"></span>
                        <span>Paper Link</span>
                      </a>
                    )}
                    {pub.data.doi && (
                      <a 
                        href={`https://doi.org/${pub.data.doi}`} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="text-fg-light no-underline hover:underline hover:text-fg-dark inline-hstack gap-1 font-mono"
                      >
                        <span>DOI: {pub.data.doi}</span>
                      </a>
                    )}
                  </div>
                </div>

                {/* illustration */}
                {pub.data.image ? (
                  <div class="w-full sm:w-48 h-36 sm:h-30 flex-shrink-0 border border-border rounded-lg overflow-hidden bg-white/10 dark:bg-black/10">
                    <img 
                      src={pub.data.image} 
                      alt={pub.data.title} 
                      class="w-full h-full object-cover" 
                    />
                  </div>
                ) : (
                  <div class="w-full sm:w-48 h-36 sm:h-30 flex-shrink-0 border border-dashed border-border rounded-lg flex items-center justify-center bg-bg-dark/10">
                    <span class="i-solar:planet-linear text-fg-light/40 text-lg"></span>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

