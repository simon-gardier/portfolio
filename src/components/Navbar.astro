---
export interface Props {
  activePage?: string;
}

const { activePage = "" } = Astro.props;
---

<header class="fixed flex justify-center items-center top-4 left-4 md:left-8 z-50 h-14 hstack border border-white/20 dark:border-white/10 bg-white/40 dark:bg-black/30 backdrop-blur-xl px-4 md:px-5 rounded-full shadow-[0_8px_32px_0_rgba(0,0,0,0.2)] dark:shadow-[0_8px_32px_0_rgba(0,0,0,0.5)] transition-all duration-300 max-w-[calc(100%-2rem)] md:max-w-max">
  <a class="font-mono font-bold text-fg-dark hover:text-fg-dark no-underline text-xs md:text-sm flex items-center gap-1 cursor-pointer transition-colors mr-6 md:mr-10" href="/">
    <span class="flex justify-center items-center">
      <span class="hidden md:inline">/home/Simon Gardier$</span>
      <span class="inline md:hidden">~/$</span>
    </span>
    <span class="w-[7px] h-[1.2em] bg-neutral-200 dark:bg-neutral-300 ml-0.5 self-center animate-smooth-blink"></span>
  </a>

  <nav class="hstack gap-x-3.5 md:gap-x-5 text-[11px] md:text-xs font-mono">
    <a
      class={`nav-item no-underline transition-colors cursor-pointer flex items-center ${activePage === "publications" ? "nav-active !text-sky-500" : ""}`}
      href="/publications"
      aria-label="Publications"
    >
      <span class="hidden md:inline">Publications</span>
      <span class="inline md:hidden i-lucide:scroll text-xs block" aria-hidden="true" title="Publications"></span>
    </a>

    <a
      class={`nav-item no-underline transition-colors cursor-pointer relative flex items-center gap-1 ${activePage === "blog" ? "nav-active !text-sky-500" : ""}`}
      href="/blog"
      aria-label="Blog"
    >
      <span class="hidden md:inline">Blog</span>
      <span class="inline md:hidden i-lucide:mail text-xs block" aria-hidden="true" title="Blog"></span>
      <span class="absolute -top-1.5 -right-2 pointer-events-none hidden md:flex">
        <img 
          src="/images/letter.png" 
          alt="Letter notification logo" 
          class="w-3.5 h-3.5 object-contain animate-breathe" 
        />
      </span>
    </a>

    <a
      class={`nav-item no-underline transition-colors cursor-pointer flex items-center ${activePage === "projects" ? "nav-active !text-sky-500" : ""}`}
      href="/projects"
      aria-label="Projects"
    >
      <span class="hidden md:inline">Projects</span>
      <span class="inline md:hidden i-lucide:pen text-xs block" aria-hidden="true" title="Projects"></span>
    </a>

    <a
      class={`p-1.5 rounded-full bg-bg-dark/40 border border-white/15 text-fg-light hover:text-fg-dark transition-all duration-200 cursor-pointer flex items-center ${activePage === "search" ? "nav-active !text-sky-500 border-sky-500/20 bg-bg-dark/50" : ""}`}
      href="/search"
      aria-label="Search"
    >
      <span class="i-uil:search text-xs block"></span>
    </a>

    <button
      id="theme-toggle"
      class="p-1.5 rounded-full bg-bg-dark/40 border border-white/15 text-fg-light hover:text-fg-dark cursor-pointer transition-all duration-200"
      aria-label="Toggle Light/Dark Theme"
    >
      {/* Light Icon */}
      <span class="i-lucide:sun text-xs block dark:hidden"></span>
      {/* Dark Icon */}
      <span class="i-lucide:moon text-xs hidden dark:block"></span>
    </button>
  </nav>
</header>
<style>
  @keyframes breathe {
    0%, 100% {
      transform: scale(1);
      opacity: 0.7;
    }
    50% {
      transform: scale(1.25) translateY(-1px);
      opacity: 1;
    }
  }
  .animate-breathe {
    animation: breathe 3s ease-in-out infinite;
    display: block;
    transform-origin: center center;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const themeBtn = document.getElementById('theme-toggle');
    if (!themeBtn) return;

    themeBtn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const nextTheme = isDark ? 'light' : 'dark';
      
      document.documentElement.classList.toggle('dark', !isDark);
      localStorage.setItem('theme', nextTheme);
    });
  });
</script>

<style>
  @keyframes smooth-blink {
    0%, 100% { 
      opacity: 0; 
    }
    30% { 
      opacity: 1; 
    }
  }
  .animate-smooth-blink {
    animation: smooth-blink 2s linear infinite;
  }
</style>
